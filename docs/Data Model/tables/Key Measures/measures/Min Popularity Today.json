{
  "name": "Min Popularity Today",
  "expression": [
    "",
    "VAR latestDate = [Latest Popularity Date]",
    "RETURN ",
    "CALCULATE(",
    "    MIN(fact_popularity[Popularity]),",
    "    fact_popularity[loaddate]= latestDate,",
    "    REMOVEFILTERS(dim_content),",
    "    fact_popularity[is_leaver]=FALSE",
    ")"
  ],
