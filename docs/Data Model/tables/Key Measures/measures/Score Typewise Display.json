{
  "name": "Score Typewise Display",
  "expression": [
    "",
    "VAR scoreMovie = SUM(dim_content[Score])",
    "VAR scoreSerie = [Avg Series Score]",
    "VAR typeContent = MAX(dim_content[TypeDisplay])",
    "RETURN ",
    "IF(",
    "    typeContent = \"Movie\",",
    "    scoreMovie,",
    "    scoreSerie",
    ")"
  ],
  "formatString": "0.0",
  "displayFolder": "Displays",
