{
  "type": "calculated",
  "name": "RuntimeDisplay",
  "dataType": "string",
  "isDataTypeInferred": true,
  "expression": [
    "",
    "VAR TotalMinutes = dim_episode[Runtime (Min.)]",
    "VAR Hours = QUOTIENT(TotalMinutes,60)",
    "VAR Minutes = MOD(TotalMinutes,60)",
    "RETURN ",
    "    SWITCH(",
    "        TRUE(),",
    "        ISBLANK(TotalMinutes),\"-\", ",
    "        Hours=0,Minutes & \"m\",",
    "        Minutes=0,Hours & \"h\",",
    "        Hours & \"h \" & Minutes & \"m\"",
    "    )"
  ],
